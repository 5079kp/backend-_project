<!DOCTYPE html>
<html>
<head>
    <title>Admin Dashboard - BookHaven</title>
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <link rel="stylesheet" href="/css/style.css">
    <link href="https://fonts.googleapis.com/css2?family=Playfair+Display:wght@400;700&family=Inter:wght@300;400;500;600&display=swap" rel="stylesheet">
</head>
<body class="form-page">
    <%- include('header') -%>

    <div class="container" style="margin-top: 120px; padding: 40px 20px;">
        <div class="glass-card" style="padding: 40px; margin-bottom: 40px;">
            <div style="display: flex; justify-content: space-between; align-items: center; flex-wrap: wrap; gap: 20px;">
                <div>
                    <h1 class="hero-title" style="margin: 0;">Admin Dashboard</h1>
                    <p style="color: #6b7280; margin: 5px 0 0 0;">Manage your book collection</p>
                </div>
                <div style="display: flex; gap: 15px;">
                    <a href="/add" class="btn btn-primary">➕ Add New Book</a>
                    <a href="/logout" class="btn btn-secondary">Logout</a>
                </div>
            </div>
        </div>

        <div class="glass-card admin-table-container">
            <div class="table-header" style="display: flex; justify-content: space-between; align-items: center; margin-bottom: 30px; flex-wrap: wrap; gap: 20px;">
                <h2 style="margin: 0;">Books (<%- books.length %>)</h2>
                <div style="display: flex; gap: 15px; align-items: center;">
                    <input type="text" id="searchInput" placeholder="Search books..." class="modern-form-input" style="width: 300px; max-width: 100%;">
                    <button id="refreshBtn" class="btn btn-secondary">Refresh</button>
                </div>
            </div>

            <div class="table-responsive">
                <table class="admin-books-table">
                    <thead>
                        <tr>
                            <th>Cover</th>
                            <th>Title</th>
                            <th>Author</th>
                            <th>Price</th>
                            <th>Genre</th>
                            <th>Date Added</th>
                            <th>Actions</th>
                        </tr>
                    </thead>
                    <tbody id="booksTableBody">
                        <% books.forEach(book => { %>
                        <tr>
                            <td><img src="/uploads/<%= book.image %>" alt="<%= book.title %>" style="width: 50px; height: 70px; object-fit: cover; border-radius: 8px;"></td>
                            <td><strong><%= book.title %></strong></td>
                            <td><%= book.author %></td>
                            <td>₹<%= book.price %></td>
                            <td><%= book.genre || 'N/A' %></td>
                            <td><%= new Date(book.createdAt).toLocaleDateString() %></td>
                            <td>
                                <div style="display: flex; gap: 10px;">
                                    <a href="/edit/<%= book._id %>" class="btn small warning">Edit</a>
                                    <a href="/delete/<%= book._id %>" class="btn small danger" onclick="return confirm('Delete <%= book.title %>?')">Delete</a>
                                    <a href="/book/<%= book._id %>" class="btn small primary" style="font-size: 0.8rem;">View</a>
                                </div>
                            </td>
                        </tr>
                        <% }) %>
                    </tbody>
                </table>
            </div>

            <% if (books.length === 0) { %>
            <div style="text-align: center; padding: 60px; color: #6b7280;">
                <h3>No books yet</h3>
                <a href="/add" class="btn btn-primary">Add your first book</a>
            </div>
            <% } %>
        </div>
    </div>

    <footer class="footer">
        <p>&copy; BookHaven - Admin Dashboard</p>
    </footer>

    <script src="https://cdnjs.cloudflare.com/ajax/libs/gsap/3.12.5/gsap.min.js"></script>
    <script>
        // Search functionality
        const searchInput = document.getElementById('searchInput');
        const booksTableBody = document.getElementById('booksTableBody');
        const refreshBtn = document.getElementById('refreshBtn');

        searchInput.addEventListener('input', (e) => {
            const term = e.target.value.toLowerCase();
            const rows = booksTableBody.querySelectorAll('tr');
            rows.forEach(row => {
                const text = row.textContent.toLowerCase();
                row.style.display = text.includes(term) ? '' : 'none';
            });
        });

        refreshBtn.addEventListener('click', () => {
            location.reload();
        });

        // GSAP animations
        gsap.from('.glass-card', {
            duration: 0.8,
            y: 50,
            opacity: 0,
            stagger: 0.2,
            ease: "power3.out"
        });
    </script>

    <style>
        .admin-table-container { max-width: 1400px; margin: 0 auto; }
        .table-responsive { overflow-x: auto; }
        .admin-books-table {
            width: 100%;
            border-collapse: collapse;
            background: white;
            border-radius: 16px;
            overflow: hidden;
            box-shadow: 0 20px 40px rgba(0,0,0,0.1);
        }
        .admin-books-table th {
            background: linear-gradient(135deg, #6366f1, #8b5cf6);
            color: white;
            padding: 20px 16px;
            text-align: left;
            font-weight: 600;
            position: sticky; top: 0;
        }
        .admin-books-table td {
            padding: 20px 16px;
            border-bottom: 1px solid #f3f4f6;
        }
        .admin-books-table tr:hover {
            background: #f8fafc;
        }
        .admin-books-table tr:last-child td { border-bottom: none; }
        @media (max-width: 768px) {
            .table-header { flex-direction: column; align-items: stretch; }
            .admin-books-table th, .admin-books-table td { padding: 12px 8px; font-size: 0.9rem; }
        }
    </style>
</body>
</html>
